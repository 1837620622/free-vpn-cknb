{
  "name": "freevpn-cknb",
  "version": "0.1.0",
  "private": true,
  "description": "免费 VPN 情报聚合站，自动同步多源试用/免费机场与节点信息",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "types:runtime": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "seed:remote": "wrangler kv key put --remote --binding VPN_DATA vpn:data --path data/vpns.json",
    "scrape": "tsx scripts/scrape.ts",
    "scrape:single": "tsx scripts/scrape.ts --source",
    "clean": "rm -rf .next .open-next .wrangler node_modules/.cache .turbo",
    "lint": "next lint"
  },
  "dependencies": {
    "cheerio": "1.1.0",
    "next": "15.5.19",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260606.1",
    "@opennextjs/cloudflare": "^1.19.11",
    "@types/node": "22.10.2",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@types/three": "^0.184.1",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.17",
    "tsx": "4.19.2",
    "typescript": "5.7.2",
    "wrangler": "^4.113.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
